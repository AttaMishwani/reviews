<div class="rf-wrapper">

  <!-- Header -->
  <div class="rf-header">
    <h3 class="rf-header-title">Leave a Review</h3>
  </div>

  <!-- Body: two columns -->
  <div class="rf-body">

    <!-- Left: Stars -->
    <div class="rf-left">
      <label class="rf-label">Your Rating <span class="rf-req">*</span></label>
      <div class="rf-stars" id="starRating">
        <span class="rf-star" data-value="1">★</span>
        <span class="rf-star" data-value="2">★</span>
        <span class="rf-star" data-value="3">★</span>
        <span class="rf-star" data-value="4">★</span>
        <span class="rf-star" data-value="5">★</span>
      </div>
      <p class="rf-hint">Click on a star to rate</p>
      <input type="hidden" id="ratingValue" value="0" />
    </div>

    <!-- Right: Review + Name + Submit -->
    <div class="rf-right">

      <div class="rf-field">
        <label class="rf-label" for="reviewText">Your Review <span class="rf-req">*</span></label>
        <textarea id="reviewText" class="rf-textarea" rows="4" placeholder="Write your review here..." maxlength="500"></textarea>
        <div class="rf-char-count"><span id="charCount">0</span>/500 characters</div>
      </div>

      <div class="rf-field">
        <label class="rf-label" for="reviewAuthor">Your Name <span class="rf-req">*</span></label>
        <input type="text" id="reviewAuthor" class="rf-input" placeholder="Your name" />
      </div>

      <div class="rf-footer">
        <p id="reviewMessage" class="rf-message"></p>
        <button id="submitReview" class="rf-btn">Submit Review</button>
      </div>

    </div>

  </div>

</div>

<script>
  window.__productId = "{{ product.id }}";
  // window.__appUrl = "{{ shop.metafields.app.url }}";
  window.__shop = "{{ shop.permanent_domain }}";
</script>

<script src="{{ 'review-form.js' | asset_url }}" defer></script>

<style>
  .rf-wrapper {
    max-width: 100%;
    width: 100%;
    margin: 32px 0;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    font-family: inherit;
  }

  /* Header */
  .rf-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 18px 28px;
    border-bottom: 1px solid #e5e7eb;
    background: #f9fafb;
  }

  .rf-header-icon {
    font-size: 20px;
  }

  .rf-header-title {
    font-size: 18px;
    font-weight: 700;
    color: #111;
    margin: 0;
  }

  /* Body */
  .rf-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    background: #f9fafb;
  }

  /* Left col */
  .rf-left {
    padding: 28px 15px;
    border-right: 1px solid #e5e7eb;
  }

  .rf-label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: #374151;
    margin-bottom: 12px;
  }

  .rf-req {
    color: #ef4444;
  }

  .rf-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 10px;
  }

  .rf-star {
    font-size: 30px;
    color: #d1d5db;
    cursor: pointer;
    transition: color 0.15s, transform 0.1s;
    line-height: 1;
  }

  .rf-star.active,
  .rf-star:hover {
    color: #f59e0b !important;
  }

  .rf-star:hover {
    transform: scale(1.1);
  }

  .rf-hint {
    font-size: 12px;
    color: #9ca3af;
    margin: 0;
  }

  /* Right col */
  .rf-right {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: #f9fafb;
  }

  .rf-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .rf-textarea,
  .rf-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    color: #111;
    background: #fff;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .rf-textarea {
    resize: vertical;
    min-height: 110px;
  }

  .rf-textarea:focus,
  .rf-input:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.08);
  }

  .rf-char-count {
    font-size: 11px;
    color: #9ca3af;
    text-align: right;
  }

  /* Footer */
  .rf-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    
    margin-top: 4px;
  }

  .rf-message {
    font-size: 13px;
    margin: 0;
    flex: 1;
  }

  .rf-message.success { color: #10b981; }
  .rf-message.error   { color: #ef4444; }

  .rf-btn {
    padding: 11px 28px;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .rf-btn:hover    { background: #374151; }
  .rf-btn:disabled { background: #9ca3af; cursor: not-allowed; }

  /* Responsive */
  @media (max-width: 640px) {
    .rf-body {
      grid-template-columns: 1fr;
    }
    .rf-left {
      border-right: none;
      border-bottom: 1px solid #e5e7eb;
    }
  }
</style>

{% schema %}
{
  "name": "Review Form",
  "target": "section",
  "settings": []
}
{% endschema %}
