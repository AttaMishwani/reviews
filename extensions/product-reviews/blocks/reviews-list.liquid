<!-- ── Reviews List ─────────────────────────────────────────────────────────── -->
<div class="rl-section">
  <div class="rl-header">
    <h3 class="rl-title">Customer Reviews</h3>
    <h3>{{ shop.domain }}</h3>
    <h3>{{ shop.permanent_domain }}</h3>
    <span class="rl-count" id="reviewCount"></span>
  </div>

  <div id="reviewsList">
    <p class="rl-empty" id="noReviews">No reviews yet. Be the first to review this product!</p>
  </div>

  <div id="seeMoreWrapper" style="display:none; text-align:center; margin-top:16px;">
    <button id="seeMoreBtn" class="rl-see-more-btn">See All Reviews</button>
  </div>
</div>

<script>
  window.__productId = "{{ product.id }}";
  window.__appUrl = "https://217f-202-47-41-0.ngrok-free.app";
  window.__shop = "{{ shop.permanent_domain }}";
</script>

<script src="{{ 'reviews-list.js' | asset_url }}" defer></script>

<style>
  .rl-section {
    width: 100%;
    margin: 32px 0;
    font-family: inherit;
  }

  .rl-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .rl-title {
    font-size: 18px;
    font-weight: 700;
    color: #111;
    margin: 0;
  }

  .rl-count {
    font-size: 13px;
    color: #9ca3af;
    background: #f3f4f6;
    padding: 2px 10px;
    border-radius: 100px;
  }

  .rl-empty {
    font-size: 14px;
    color: #9ca3af;
    padding: 24px;
    background: #fafafa;
    border: 1px solid #f3f4f6;
    border-radius: 12px;
    text-align: center;
    margin: 0;
  }

  .rl-card {
    /* background: #fff; */
   padding: 20px ;
 
   
    width: 100%;
    box-sizing: border-box;
  }

  .rl-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* margin-bottom: 8px; */
  }

  .rl-card-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .rl-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .rl-author {
    font-size: 14px;
    font-weight: 700;
    color: #111;
  }

  .rl-date {
    font-size: 12px;
    color: #9ca3af;
  }

  .rl-stars {
    font-size: 15px;
    color: #f59e0b;
    letter-spacing: 2px;
    /* margin-bottom: 10px; */
    margin-left: 46px;
  }

  .rl-stars span {
    color: #d1d5db;
  }

  .rl-text {
    font-size: 14px;
    color: #555;
    line-height: 1.65;
    margin: 0;
    margin-left: 46px;
  }

  .rl-see-more-btn {
    padding: 10px 28px;
    background: #fff;
    color: #111;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }

  .rl-see-more-btn:hover {
    background: #f9fafb;
    border-color: #d1d5db;
  }
</style>

{% schema %}
{
  "name": "Review List",
  "target": "section",
  "settings": []
}
{% endschema %}
